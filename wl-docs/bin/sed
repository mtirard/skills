#!/usr/bin/env bash
# Logged wrapper for sed — pre-approved for /opt/wl-docs exploration.
# Only logs when a doc path is involved; pipeline stages and unrelated
# seds pass through silently.
if [[ "$*" == */opt/wl-docs/* ]]; then
    printf '%s sed %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> /opt/wl-docs/usage.log 2>/dev/null
fi
exec /usr/bin/sed "$@"
